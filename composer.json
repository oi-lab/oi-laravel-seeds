{
    "name": "oi-lab/oi-laravel-seeds",
    "description": "Export and import Laravel seeders to/from JSON files with dependency management",
    "type": "library",
    "keywords": [
        "laravel",
        "seeder",
        "export",
        "import",
        "json",
        "database",
        "oi-lab"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "OI Lab",
            "email": "olivier@olacombe.com"
        }
    ],
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0|^4.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "OiLab\\OiLaravelSeeds\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OiLab\\OiLaravelSeeds\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OiLab\\OiLaravelSeeds\\OiLaravelSeedsServiceProvider"
            ]
        },
        "oi-lab": {
            "skills": [
                {
                    "name": "oilab-laravel-seeds",
                    "description": "Export and import seeders to/from JSON with dependency management",
                    "path": "resources/stubs/ai-skill.md",
                    "rules": "resources/stubs/claude-rules.md",
                    "section": "oi-lab/oi-laravel-seeds rules"
                }
            ]
        }
    },
    "scripts": {
        "sync-ai-skills": [
            "@php scripts/sync-ai-skills.php"
        ],
        "post-autoload-dump": [
            "@php scripts/sync-ai-skills.php"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
