{
    "name": "oi-lab/oi-laravel-seeds",
    "description": "Export and import Laravel seeders to/from JSON files with dependency management",
    "type": "library",
    "keywords": [
        "laravel",
        "seeder",
        "export",
        "import",
        "json",
        "database",
        "oi-lab"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "OI Lab",
            "email": "contact@oi-lab.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/filesystem": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0|^4.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "OiLab\\LaravelSeeds\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OiLab\\LaravelSeeds\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OiLab\\LaravelSeeds\\LaravelSeedsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
